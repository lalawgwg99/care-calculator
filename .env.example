# ===========================================
# 網站基礎設定
# ===========================================

# 網站公開 URL（用於 SEO、Sitemap、Open Graph）
# 開發環境
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# 生產環境（Vercel 部署時設為實際網址）
# NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# ===========================================
# 資料庫設定 (Phase 2+ 使用)
# ===========================================

# Supabase PostgreSQL 連線字串
DATABASE_URL="postgresql://user:password@host:5432/database"

# ===========================================
# 分析工具
# ===========================================

# Google Analytics 追蹤 ID（可選）
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Google Search Console 驗證碼（可選）
# 取得方式：Search Console -> 設定 -> 擁有權驗證（HTML 標記）
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION="xxxxxxxxxxxxxxxxxxxx"

# ===========================================
# API 設定
# ===========================================

NEXT_PUBLIC_API_URL="http://localhost:3000"
